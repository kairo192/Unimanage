# ─── Server ───────────────────────────
PORT=5050
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:port/database

# ─── Auth ─────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-hex-string
ADMIN_EMAIL=admin@blida2.dz
# DEFAULT_ADMIN_PASSWORD=set-this-on-first-deploy-only

# ─── AI ────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
AI_MODEL=google/gemma-4-26b-a4b-it:free

# ─── CORS / URL ────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173
# The public URL of this API server (Railway/Render URL)
APP_URL=http://localhost:5050

# ─── Supabase Storage (for image uploads) ──
# Get these from Supabase Dashboard → Settings → API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=tickets
